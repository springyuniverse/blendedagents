FROM node:20-alpine

WORKDIR /app

# Install ALL dependencies (tsx is in devDeps but needed at runtime)
# Force NODE_ENV=development during install so npm doesn't skip devDeps
COPY package.json package-lock.json* ./
RUN NODE_ENV=development npm ci

# Copy source
COPY src/ ./src/
COPY tsconfig.json ./

ENV NODE_ENV=production
EXPOSE 4000

CMD ["node", "--import", "tsx", "src/server.ts"]
